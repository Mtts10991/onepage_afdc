# =============================================================================
# OnePage – Environment variables (example)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# Database
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
# (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# Seeded admin account (only used by prisma/seed.ts on first run)
# Use a strong random password — DO NOT keep the default for production.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"
ADMIN_NAME="System Administrator"

# File uploads
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_MB="10"
