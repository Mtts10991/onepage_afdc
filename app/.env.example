# =============================================================================
# OnePage – Local development environment
# DO NOT commit this file. Rotate secrets if it ever leaks.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres — project qlmvobwnhhxblgshlskl, ap-northeast-1)
# -----------------------------------------------------------------------------
# Password Afdc@gso2026# is URL-encoded as Afdc%40gso2026%23 (@ → %40, # → %23)
# DATABASE_URL = pooled (pgbouncer port 6543) — used by Next.js runtime
# DIRECT_URL   = direct (port 5432)            — used ONLY by prisma migrate / introspect
DATABASE_URL="file:./dev.db"
DIRECT_URL=

# -----------------------------------------------------------------------------
# Auth.js
# -----------------------------------------------------------------------------
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Bootstrap admin (used once by `pnpm db:seed`)
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"
ADMIN_NAME="System Administrator"

# -----------------------------------------------------------------------------
# File uploads
# -----------------------------------------------------------------------------
UPLOAD_DIR="./public/uploads"
# Must stay <= the Supabase `uploads` bucket file_size_limit. Uploads go
# browser -> Supabase via a signed URL (/api/upload/sign), so they are NOT
# bound by Vercel's 4.5 MB serverless-function payload cap.
MAX_UPLOAD_MB="25"

# Supabase Storage (server-only, used by /api/upload after Phase C refactor)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# LINE Login (M2) — Channel ID + Channel Secret of the LINE Login channel
# -----------------------------------------------------------------------------
AUTH_LINE_ID=
AUTH_LINE_SECRET=

# -----------------------------------------------------------------------------
# LINE Messaging API (M3) — Channel access token + secret of the OA channel
# IMPORTANT: these come from the Messaging API channel, NOT the Login channel.
# The current LINE_CHANNEL_ACCESS_TOKEN value looks like a channel secret
# copy-pasted from the Login channel; replace it with the long-lived token
# from Messaging API → Channel access token. LINE_CHANNEL_SECRET should be
# the Basic settings → Channel secret of the Messaging API channel.
# -----------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_OA_ADD_URL=

# -----------------------------------------------------------------------------
# Vercel Cron auth (M3)
# -----------------------------------------------------------------------------
CRON_SECRET=
