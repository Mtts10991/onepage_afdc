# =============================================================================
# OnePage – Local development environment
# DO NOT commit this file. Rotate secrets if it ever leaks.
# =============================================================================

DATABASE_URL="file:./dev.db"

# Generated with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"

# IMPORTANT: change ADMIN_PASSWORD before running `pnpm db:seed` for the first time.
# The seed is idempotent, so you must also rotate the password manually via /profile if you already seeded.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"
ADMIN_NAME="System Administrator"

UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_MB="10"

AUTH_LINE_ID=
AUTH_LINE_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
SECRET=
LINE_OA_ADD_URL=
CRON_SECRET=
