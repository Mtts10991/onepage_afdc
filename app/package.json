    "isomorphic-dompurify": "^3.12.0",
    "lucide-react": "^0.460.0",
    "next": "^16.0.0",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "^4.4.0",
    "next-themes": "^0.4.4",
    "pptxgenjs": "^3.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
