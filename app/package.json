    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.5.0",
    "prisma": "5.22.0",
    "sass": "^1.82.0",
    "tailwindcss": "^4.0.0",
